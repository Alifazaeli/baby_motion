DEBUG=True
SECRET_KEY=change-me-in-production
DATABASE_URL=postgres://user:password@localhost:5432/baby_motion

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Arvan Cloud (S3-compatible)
ARVAN_ACCESS_KEY=your-arvan-access-key
ARVAN_SECRET_KEY=your-arvan-secret-key
ARVAN_BUCKET=storytelling-prod
ARVAN_CDN_DOMAIN=cdn.arvanstorage.ir

# Sentry
SENTRY_DSN=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
